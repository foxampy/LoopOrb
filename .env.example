# LoopOrb Platform Environment Variables

# Database - PostgreSQL on Render.com
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://looporb_user:password@localhost:5432/looporb_db"

# Direct connection for migrations (Render specific)
DIRECT_URL=""

# JWT Secret - generate strong random string
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Telegram Bot (for Mini App integration)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# File Upload (optional - for production)
# AWS S3 or Cloudflare R2
UPLOAD_PROVIDER="local" # or "s3" or "r2"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# Email (optional)
EMAIL_PROVIDER="" # or "sendgrid" or "smtp"
SENDGRID_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_ID=""
