// LoopOrb Platform Database Schema
// PostgreSQL on Render.com

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS & AUTHENTICATION
// ==========================================

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  password      String?   // hashed
  name          String
  handle        String?   @unique // @username
  avatar        String?
  bio           String?   @db.Text
  
  // OAuth providers
  googleId      String?   @unique
  telegramId    String?   @unique
  
  // Role system
  role          UserRole  @default(CITIZEN)
  isAdmin       Boolean   @default(false)
  
  // Gamification
  level         Int       @default(1)
  xp            Int       @default(0)
  reputation    Int       @default(0)
  
  // Wallet (UNITY coins - offchain)
  unityBalance  Decimal   @default(0) @db.Decimal(18, 8)
  stakedAmount  Decimal   @default(0) @db.Decimal(18, 8)
  
  // VODeco 3-token system
  vodBalance    Decimal   @default(0) @db.Decimal(18, 8)   // Commodity token
  vodecoBalance Decimal   @default(0) @db.Decimal(18, 8)   // Governance token
  vodcreditScore Int      @default(0)                      // Reputation SBT
  
  // Status
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  wallet        Wallet?
  transactions  Transaction[]
  stakes        Stake[]
  posts         Post[]
  comments      Comment[]
  projects      ProjectMember[]
  objects       WaterObject[] // Created objects
  createdProjects Project[]   @relation("CreatedProjects")
  authoredProposals Proposal[] @relation("AuthoredProposals")
  data          WaterData[]
  votes         DaoVote[]
  achievements  UserAchievement[]
  missions      UserMission[]
  sessions      Session[]
  notifications Notification[]
  followers     Follow[] @relation("UserFollowers")
  following     Follow[] @relation("UserFollowing")
  
  // Chat relations
  chatParticipants ChatParticipant[]
  messages        Message[]
  
  // Groups
  ownedGroups     Group[] @relation("GroupOwner")
  groupMemberships GroupMember[]
  
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

enum UserRole {
  CITIZEN      // Обычный пользователь
  SCIENTIST    // Ученый/исследователь
  INVESTOR     // Инвестор
  GOVERNMENT   // Государственный служащий
  OPERATOR     // Оператор инфраструктуры
  ADMIN        // Администратор
}

// ==========================================
// WALLET & ECONOMY (3-TOKEN SYSTEM)
// ==========================================

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  
  // UNITY Coin (legacy - off-chain)
  balance     Decimal  @default(0) @db.Decimal(18, 8)
  
  // VODeco 3-Token System
  vodBalance     Decimal  @default(0) @db.Decimal(18, 8)  // Commodity
  vodecoBalance  Decimal  @default(0) @db.Decimal(18, 8)  // Governance
  vodcreditScore Int      @default(0)                     // Reputation
  
  // Staking info
  totalStaked Decimal  @default(0) @db.Decimal(18, 8)
  totalEarned Decimal  @default(0) @db.Decimal(18, 8)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("wallets")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  
  type        TransactionType
  tokenType   TokenType       @default(UNITY)  // UNITY, VOD, VODeco
  amount      Decimal         @db.Decimal(18, 8)
  
  // Context
  projectId   String?
  description String?
  metadata    Json?           // Additional context
  
  status      TransactionStatus @default(COMPLETED)
  
  createdAt   DateTime        @default(now())
  
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?        @relation(fields: [projectId], references: [id])
  
  @@index([userId])
  @@index([createdAt])
  @@map("transactions")
}

enum TokenType {
  UNITY
  VOD         // Commodity - backed by water
  VODeco      // Governance
}

enum TransactionType {
  // System
  REGISTRATION_BONUS
  DAILY_BONUS
  REFERRAL_BONUS
  
  // Actions
  ADD_OBJECT
  ADD_DATA
  VALIDATE_DATA
  
  // Rewards
  MISSION_REWARD
  ACHIEVEMENT_REWARD
  
  // Staking
  STAKE
  UNSTAKE
  STAKE_REWARD
  
  // Transfers
  TRANSFER_IN
  TRANSFER_OUT
  
  // Projects
  PROJECT_CONTRIBUTION
  PROJECT_REWARD
  
  // Tokenomics v3
  VOD_MINT          // Mint VOD (verified water)
  VOD_BURN          // Burn VOD
  VODECO_STAKE      // Stake governance
  VODECO_UNSTAKE    // Unstake governance
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ==========================================
// STAKING SYSTEM
// ==========================================

model Stake {
  id          String      @id @default(uuid())
  userId      String
  projectId   String
  
  amount      Decimal     @db.Decimal(18, 8)
  tokenType   TokenType   @default(VODeco)  // VODeco for governance
  apy         Decimal     @db.Decimal(5, 2) // Annual percentage yield
  
  startDate   DateTime    @default(now())
  endDate     DateTime?   // Null = indefinite
  lastRewardAt DateTime   @default(now())
  
  totalRewarded Decimal  @default(0) @db.Decimal(18, 8)
  
  status      StakeStatus @default(ACTIVE)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([projectId])
  @@map("stakes")
}

enum StakeStatus {
  ACTIVE
  UNSTAKING // В процессе вывода
  COMPLETED
  CANCELLED
}

// ==========================================
// PROJECTS
// ==========================================

model Project {
  id              String          @id @default(uuid())
  slug            String          @unique
  
  name            String
  description     String          @db.Text
  shortDescription String
  
  // Classification
  type            ProjectType
  category        ProjectCategory
  status          ProjectStatus   @default(DRAFT)
  
  // Location
  country         String
  region          String?
  city            String?
  coordinates     Json?           // { lat: number, lng: number }
  
  // Financial
  targetAmount    Decimal?        @db.Decimal(18, 2)
  raisedAmount    Decimal         @default(0) @db.Decimal(18, 2)
  minStake        Decimal         @default(100) @db.Decimal(18, 8)
  
  // Returns
  expectedApy     Decimal?        @db.Decimal(5, 2)
  expectedReturn  Decimal?        @db.Decimal(18, 2)
  irr             Decimal?        @db.Decimal(5, 2) // Internal Rate of Return
  
  // ESG & Impact
  esgScore        Int?            // 0-100
  sdgGoals        Int[]           // [6, 9, 11, 13, 16]
  impactMetrics   Json?           // { waterSaved: number, peopleHelped: number, etc }
  
  // Media
  coverImage      String?
  gallery         String[]
  documents       Json[]          // [{ name, url, type, uploadedAt }]
  
  // Timeline
  startDate       DateTime?
  endDate         DateTime?
  
  // Relations
  creatorId       String
  creator         User            @relation(fields: [creatorId], references: [id], name: "CreatedProjects")
  
  members         ProjectMember[]
  objects         ProjectObject[]
  milestones      Milestone[]
  stakes          Stake[]
  transactions    Transaction[]
  posts           Post[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([status])
  @@index([type])
  @@index([country])
  @@map("projects")
}

model ProjectMember {
  id        String           @id @default(uuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  
  joinedAt  DateTime         @default(now())
  
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectObject {
  id        String       @id @default(uuid())
  projectId String
  objectId  String
  
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  object    WaterObject  @relation(fields: [objectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, objectId])
  @@map("project_objects")
}

model Milestone {
  id          String        @id @default(uuid())
  projectId   String
  
  title       String
  description String?       @db.Text
  
  dueDate     DateTime?
  completedAt DateTime?
  
  status      MilestoneStatus @default(PENDING)
  
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("milestones")
}

enum ProjectType {
  INFRASTRUCTURE       // Модернизация инфраструктуры
  RESTORATION          // Восстановление экосистем
  RESEARCH             // Исследования
  MONITORING           // Мониторинг
  EDUCATION            // Образование
  TECHNOLOGY           // Разработка технологий
}

enum ProjectCategory {
  WATER_TREATMENT      // Очистка воды
  INFRASTRUCTURE       // Инфраструктура
  CONSERVATION         // Сохранение
  RESEARCH             // Исследования
  COMMUNITY            // Сообщество
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW       // На рассмотрении
  ACTIVE               // Активен
  FUNDING              // Сбор средств
  IN_PROGRESS          // В работе
  COMPLETED            // Завершен
  CANCELLED            // Отменен
}

enum ProjectMemberRole {
  MEMBER
  CONTRIBUTOR
  MANAGER
  LEAD
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// ==========================================
// WATER OBJECTS
// ==========================================

model WaterObject {
  id            String        @id @default(uuid())
  
  name          String
  nameLocal     String?       // Локальное название
  
  type          ObjectType
  subtype       String?       // Уточнение типа
  
  // Location
  country       String
  region        String?
  city          String?
  coordinates   Json          // { lat: number, lng: number }
  
  // Classification
  basin         String?       // Водосборный бассейн
  watershed     String?       // Водораздел
  
  // Current status
  status        ObjectStatus  @default(ACTIVE)
  qualityIndex  Int?          // 0-100
  
  // Description
  description   String?       @db.Text
  history       String?       @db.Text
  threats       String[]      // Угрозы
  
  // Media
  images        String[]
  
  // Relations
  creatorId     String
  creator       User          @relation(fields: [creatorId], references: [id])
  
  data          WaterData[]
  projects      ProjectObject[]
  posts         Post[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([type])
  @@index([country])
  @@index([status])
  @@map("water_objects")
}

model WaterData {
  id            String        @id @default(uuid())
  
  objectId      String
  object        WaterObject   @relation(fields: [objectId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  
  // Measurement
  measuredAt    DateTime      @default(now())
  location      Json?         // { lat: number, lng: number } если отличается от объекта
  
  // Water metrics
  ph            Float?
  temperature   Float?        // Celsius
  turbidity     Float?        // NTU
  tds           Float?        // Total Dissolved Solids, ppm
  conductivity  Float?        // µS/cm
  dissolvedOxygen Float?      // mg/L
  
  // Chemical
  nitrates      Float?        // mg/L
  phosphates    Float?        // mg/L
  
  // Biological
  bacteriaCount Float?
  
  // Visual
  clarity       Int?          // 0-10
  color         String?
  odor          String?
  
  // Images
  images        String[]
  
  // Validation
  status        DataStatus    @default(PENDING)
  validatedBy   String?       // User ID who validated
  validatedAt   DateTime?
  notes         String?       @db.Text
  
  // Hash for future tokenization
  dataHash      String?       // SHA-256 hash for future anchoring
  
  createdAt     DateTime      @default(now())
  
  @@index([objectId])
  @@index([userId])
  @@index([measuredAt])
  @@index([status])
  @@map("water_data")
}

enum ObjectType {
  // Природные
  RIVER
  LAKE
  POND
  STREAM
  SPRING
  WETLAND
  GLACIER
  AQUIFER
  SEA
  OCEAN
  
  // Инфраструктурные
  WATER_TREATMENT_PLANT
  PUMPING_STATION
  RESERVOIR
  DAM
  PIPELINE
  WELL
  
  // Другое
  MONITORING_STATION
  RESEARCH_SITE
}

enum ObjectStatus {
  ACTIVE
  MONITORING
  RESTORATION
  CRITICAL
  INACTIVE
}

enum DataStatus {
  PENDING      // Ожидает валидации
  VALIDATED    // Подтверждено
  REJECTED     // Отклонено
  EXPERT       // Экспертные данные
}

// ==========================================
// SOCIAL NETWORK
// ==========================================

model Post {
  id          String    @id @default(uuid())
  
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content     String    @db.Text
  images      String[]
  
  // Engagement
  likes       Like[]
  comments    Comment[]
  
  likesCount    Int     @default(0)
  commentsCount Int     @default(0)
  sharesCount   Int     @default(0)
  
  // Context
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id])
  objectId    String?
  object      WaterObject? @relation(fields: [objectId], references: [id])
  
  // Mentions & hashtags
  mentions    String[]  // @username
  hashtags    String[]
  
  // Post type
  type        PostType  @default(GENERAL)
  priority    Int       @default(0)  // For feed algorithm
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([authorId])
  @@index([createdAt])
  @@index([type])
  @@map("posts")
}

enum PostType {
  GENERAL       // Обычный пост
  NEWS          // Новости
  PROJECT_UPDATE // Обновление проекта
  DATA_REPORT   // Отчет о данных
  DAO_PROPOSAL  // Предложение DAO
  ACHIEVEMENT   // Достижение
  CRISIS_ALERT  // Кризисное уведомление
}

model Comment {
  id        String   @id @default(uuid())
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content   String   @db.Text
  
  // Nested replies
  parentId  String?
  replies   Comment[] @relation("CommentReplies")
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("comments")
}

model Like {
  id        String   @id @default(uuid())
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  
  createdAt DateTime @default(now())
  
  @@unique([postId, userId])
  @@map("likes")
}

model Follow {
  id          String   @id @default(uuid())
  
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@map("follows")
}

// ==========================================
// CHATS & MESSAGING
// ==========================================

model Chat {
  id          String    @id @default(uuid())
  
  type        ChatType  @default(DIRECT)
  name        String?   // For groups
  avatar      String?   // For groups
  
  // For project/group chats
  projectId   String?
  groupId     String?
  
  // Metadata
  lastMessageAt DateTime @default(now())
  lastMessage   String?  @db.Text
  
  // Relations
  participants  ChatParticipant[]
  messages      Message[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("chats")
}

enum ChatType {
  DIRECT    // 1-on-1
  GROUP     // Group chat
  PROJECT   // Project channel
  SUPPORT   // Support chat
}

model ChatParticipant {
  id        String   @id @default(uuid())
  
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role      ChatRole @default(MEMBER)
  
  // Tracking
  lastReadAt DateTime @default(now())
  unreadCount Int    @default(0)
  
  joinedAt  DateTime @default(now())
  
  @@unique([chatId, userId])
  @@map("chat_participants")
}

enum ChatRole {
  MEMBER
  MODERATOR
  ADMIN
  OWNER
}

model Message {
  id        String   @id @default(uuid())
  
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content   String   @db.Text
  type      MessageType @default(TEXT)
  
  // Media
  attachments String[] // URLs
  
  // Status
  isEdited  Boolean  @default(false)
  editedAt  DateTime?
  
  // Reply
  replyToId String?
  
  createdAt DateTime @default(now())
  
  @@index([chatId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM    // System messages (user joined, etc)
}

// ==========================================
// GROUPS & COMMUNITIES
// ==========================================

model Group {
  id          String    @id @default(uuid())
  
  name        String
  slug        String    @unique
  description String    @db.Text
  
  // Media
  avatar      String?
  coverImage  String?
  
  // Settings
  type        GroupType @default(PUBLIC)
  category    GroupCategory @default(GENERAL)
  
  // Stats
  membersCount Int      @default(0)
  postsCount   Int      @default(0)
  
  // Relations
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], name: "GroupOwner")
  
  memberships GroupMember[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("groups")
}

enum GroupType {
  PUBLIC      // Anyone can join
  RESTRICTED  // Request to join
  PRIVATE     // Invite only
}

enum GroupCategory {
  GENERAL
  REGIONAL      // By geography
  PROJECT       // Project-related
  SCIENTIFIC    // Research groups
  EDUCATIONAL   // Learning
  ACTIVIST      // Activism
}

model GroupMember {
  id        String    @id @default(uuid())
  
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role      GroupMemberRole @default(MEMBER)
  
  joinedAt  DateTime  @default(now())
  
  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupMemberRole {
  MEMBER
  CONTRIBUTOR
  MODERATOR
  ADMIN
}

// ==========================================
// GAMIFICATION
// ==========================================

model Achievement {
  id            String   @id @default(uuid())

  name          String   @unique
  description   String   @db.Text

  category      AchievementCategory
  rarity        AchievementRarity @default(COMMON)
  nftMetal      NFDMetal @default(BRONZE)
  icon          String
  color         String

  // Requirements
  xpReward      Int
  orbReward     Decimal  @default(0) @db.Decimal(18, 8)  // Renamed from unityReward
  hasNFTBadge   Boolean  @default(true)

  // Unlock conditions
  condition     Json     // { type: "projects_count", value: 5 }
  
  // Visual & Collection
  visualDescription String? @db.Text
  animationType String   @default("float")
  collectionValue Int    @default(1)

  users         UserAchievement[]

  createdAt     DateTime @default(now())

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  progress      Int         @default(0)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

model Mission {
  id          String    @id @default(uuid())
  
  title       String
  description String    @db.Text
  
  type        MissionType
  category    MissionCategory
  
  // Requirements
  requirements Json     // { action: "add_data", count: 3 }
  
  // Rewards
  xpReward    Int
  unityReward Decimal  @default(0) @db.Decimal(18, 8)
  vodReward   Decimal  @default(0) @db.Decimal(18, 8)
  
  // Availability
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  
  users       UserMission[]
  
  createdAt   DateTime  @default(now())
  
  @@map("missions")
}

model UserMission {
  id          String        @id @default(uuid())
  
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  missionId   String
  mission     Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  
  progress    Int           @default(0)
  target      Int
  
  status      UserMissionStatus @default(ACTIVE)
  
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  
  @@unique([userId, missionId])
  @@map("user_missions")
}

enum AchievementCategory {
  WATER_MONITORING   // Водный мониторинг
  SOCIAL             // Социальные
  PROJECT            // Проектные
  RESEARCH           // Исследования
  EDUCATION          // Образование
  SPECIAL            // Специальные
  EXPLORER           // Исследователь (legacy)
  SCIENTIST          // Ученый (legacy)
  ACTIVIST           // Активист (legacy)
  INVESTOR           // Инвестор (legacy)
  INFLUENCER         // Лидер мнений (legacy)
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum NFDMetal {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum MissionType {
  DAILY
  WEEKLY
  MONTHLY
  ONETIME
  PROJECT
}

enum MissionCategory {
  DATA_COLLECTION
  VALIDATION
  PROJECT_PARTICIPATION
  SOCIAL
  EDUCATION
  EXPLORATION
}

enum UserMissionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ==========================================
// DAO GOVERNANCE
// ==========================================

model Proposal {
  id          String          @id @default(uuid())
  
  title       String
  description String          @db.Text
  
  category    ProposalCategory
  status      ProposalStatus  @default(ACTIVE)
  
  // Voting
  votesFor    Decimal         @default(0) @db.Decimal(18, 8)
  votesAgainst Decimal        @default(0) @db.Decimal(18, 8)
  votesAbstain Decimal         @default(0) @db.Decimal(18, 8)
  
  // Timeline
  startDate   DateTime
  endDate     DateTime
  
  // Result
  executedAt  DateTime?
  executionResult Json?
  
  // Relations
  authorId    String
  author      User            @relation(fields: [authorId], references: [id], name: "AuthoredProposals")
  votes       DaoVote[]
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([status])
  @@index([endDate])
  @@map("proposals")
}

model DaoVote {
  id          String   @id @default(uuid())
  
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  vote        VoteType
  weight      Decimal  @db.Decimal(18, 8) // VODeco power
  
  reason      String?  @db.Text
  
  createdAt   DateTime @default(now())
  
  @@unique([proposalId, userId])
  @@map("dao_votes")
}

enum ProposalCategory {
  TREASURY
  PROJECT_FUNDING
  PLATFORM_UPGRADE
  PARAMETER_CHANGE
  ECOSYSTEM
}

enum ProposalStatus {
  DRAFT
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
  CANCELLED
}

enum VoteType {
  FOR
  AGAINST
  ABSTAIN
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id          String           @id @default(uuid())
  
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String
  message     String           @db.Text
  
  // Context
  data        Json?            // { postId, userId, projectId, etc }
  
  isRead      Boolean          @default(false)
  readAt      DateTime?
  
  createdAt   DateTime         @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  SYSTEM
  PROJECT_UPDATE
  PROJECT_INVITE
  MISSION_COMPLETED
  ACHIEVEMENT_UNLOCKED
  DATA_VALIDATED
  STAKE_REWARD
  TRANSFER_RECEIVED
  POST_LIKE
  POST_COMMENT
  POST_MENTION
  FOLLOW
  DAO_VOTE
  PROPOSAL_ENDED
  CHAT_MESSAGE
  GROUP_INVITE
}

// ==========================================
// ACTIVITY LOG (for feed algorithm)
// ==========================================

model ActivityLog {
  id          String   @id @default(uuid())
  
  userId      String
  type        ActivityType
  
  // Context
  metadata    Json?    // { projectId, postId, etc }
  
  // For scoring
  score       Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum ActivityType {
  POST_CREATED
  POST_LIKED
  POST_COMMENTED
  PROJECT_JOINED
  DATA_ADDED
  DATA_VALIDATED
  MISSION_COMPLETED
  ACHIEVEMENT_UNLOCKED
  STAKE_CREATED
  DAO_VOTED
}
